{
  "name": "@browsertrace/browsertrace",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "browsertrace": "dist/cli/main.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "build:release:bundle": "tsup src/cli/pkg-main.ts --format cjs --platform node --target node18 --out-dir dist-pkg",
    "build:release": "pnpm run build:release:bundle && node ./scripts/build-release.mjs",
    "test": "vitest run",
    "clean": "rm -rf dist dist-pkg coverage releases"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.1.0",
    "@opentelemetry/core": "^2.1.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0",
    "commander": "^14.0.1",
    "playwright-core": "1.45.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "pkg": "^5.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
